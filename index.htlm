<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Livraison repas senior Toulouse — AXEO Services</title>
  <meta name="description" content="Livraison de repas équilibrés pour seniors à Toulouse. Repas chauds livrés 7j/7. Devis gratuit. Crédit d'impôt 50%. AXEO Services Toulouse." />

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "AXEO Services Toulouse",
    "telephone": "+33531220021",
    "address": {"@type":"PostalAddress","streetAddress":"14 Rue des Platanes","addressLocality":"Toulouse","postalCode":"31170","addressCountry":"FR"},
    "areaServed": "Toulouse et agglomération",
    "url": "https://axeo-toulouse.fr/livraison-repas/",
    "contactPoint": {"@type":"ContactPoint","telephone":"+33531220021","contactType":"customer service","areaServed":"FR"}
  }
  </script>

  <!-- Google Consent Mode v2 — AVANT gtag !! -->
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    // ⚠ Valeurs par défaut = DENIED jusqu'au consentement
    gtag('consent', 'default', {
      analytics_storage:     'denied',
      ad_storage:            'denied',
      ad_user_data:          'denied',
      ad_personalization:    'denied',
      wait_for_update:       500
    });
  </script>

  <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXX"></script>
  <script>
    gtag('js', new Date());
    gtag('config', 'G-XXXXXXXX', { send_page_view: true });

    function trackCall(label) {
      if (typeof gtag !== 'undefined') {
        gtag('event', 'tel_click', { event_category: 'contact', event_label: label||'cta', value: 45, currency: 'EUR' });
      }
    }
    function trackForm() {
      if (typeof gtag !== 'undefined') {
        gtag('event', 'form_submit', { event_category: 'lead', event_label: 'rappel_repas_senior_toulouse', value: 65, currency: 'EUR' });
      }
    }

    // Consent Mode helpers
    function grantConsent() {
      gtag('consent', 'update', {
        analytics_storage:  'granted',
        ad_storage:         'granted',
        ad_user_data:       'granted',
        ad_personalization: 'granted'
      });
      localStorage.setItem('axeo_consent', 'granted');
    }
    function denyConsent() {
      gtag('consent', 'update', {
        analytics_storage:  'denied',
        ad_storage:         'denied',
        ad_user_data:       'denied',
        ad_personalization: 'denied'
      });
      localStorage.setItem('axeo_consent', 'denied');
    }

    // Restaurer consentement si déjà choisi
    (function() {
      var c = localStorage.getItem('axeo_consent');
      if (c === 'granted') grantConsent();
    })();
  </script>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;600;700;800&family=Nunito+Sans:wght@300;400;600&display=swap" rel="stylesheet">

  <style>
    :root {
      --axeo-orange:    #F29400;
      --axeo-orange-dk: #D07D00;
      --axeo-orange-lt: #FFF3DC;
      --axeo-gray:      #3D3D3D;
      --axeo-gray-lt:   #F7F7F7;
      --axeo-gray-md:   #6B6B6B;
      --white:          #FFFFFF;
      --radius:         14px;
      --shadow-sm:      0 2px 12px rgba(0,0,0,.06);
      --shadow-md:      0 6px 28px rgba(0,0,0,.10);
      --shadow-lg:      0 16px 48px rgba(0,0,0,.13);
      --ff-head:        'Nunito', sans-serif;
      --ff-body:        'Nunito Sans', sans-serif;
      --ease:           cubic-bezier(.4,0,.2,1);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: var(--ff-body); color: var(--axeo-gray); background: var(--white); line-height: 1.65; overflow-x: hidden; }
    img  { max-width: 100%; height: auto; display: block; }
    a    { color: inherit; text-decoration: none; }

    .container { max-width: 1080px; margin: 0 auto; padding: 0 20px; }
    section { padding: 72px 0; }

    /* ═══ BOUTONS ═══════════════════════════════════════════════ */
    .btn-orange {
      display: inline-flex; align-items: center; gap: 8px;
      background: var(--axeo-orange); color: var(--white);
      font-family: var(--ff-head); font-weight: 800; font-size: 1rem;
      padding: 15px 32px; border-radius: 50px; border: none; cursor: pointer;
      transition: all .25s var(--ease);
      box-shadow: 0 4px 20px rgba(242,148,0,.35);
      text-decoration: none; white-space: nowrap;
    }
    .btn-orange:hover { background: var(--axeo-orange-dk); transform: translateY(-2px); box-shadow: 0 8px 28px rgba(242,148,0,.45); }

    .btn-outline {
      display: inline-flex; align-items: center; gap: 8px;
      background: transparent; color: var(--axeo-gray);
      font-family: var(--ff-head); font-weight: 700; font-size: .95rem;
      padding: 14px 28px; border-radius: 50px;
      border: 2px solid rgba(61,61,61,.25);
      cursor: pointer; transition: all .25s var(--ease); text-decoration: none;
    }
    .btn-outline:hover { border-color: var(--axeo-orange); color: var(--axeo-orange); }

    /* ═══ EYEBROW / TITRES ══════════════════════════════════════ */
    .eyebrow {
      display: block; font-family: var(--ff-head); font-size: .75rem;
      font-weight: 800; text-transform: uppercase; letter-spacing: .1em;
      color: var(--axeo-orange); margin-bottom: 10px;
    }
    .sec-h2 {
      font-family: var(--ff-head); font-weight: 800;
      font-size: clamp(1.6rem, 3.5vw, 2.3rem);
      color: var(--axeo-gray); line-height: 1.15; margin-bottom: 14px;
    }
    .sec-h2 span { color: var(--axeo-orange); }
    .sec-intro { font-size: .97rem; color: var(--axeo-gray-md); max-width: 540px; }

    .pill {
      display: inline-block; background: var(--axeo-orange-lt);
      color: var(--axeo-orange-dk); font-family: var(--ff-head);
      font-size: .73rem; font-weight: 800;
      padding: 5px 14px; border-radius: 20px;
      letter-spacing: .06em; text-transform: uppercase;
    }

    /* ═══════════════════════════════════════════════════════════
       BANDEAU COOKIES CNIL — Google Consent Mode v2
       ⚠ Obligatoire si GA4 + Google Ads sur la page
    ══════════════════════════════════════════════════════════ */
    #cookie-banner {
      position: fixed; bottom: 0; left: 0; right: 0; z-index: 9999;
      background: var(--axeo-gray); color: var(--white);
      padding: 20px 24px;
      box-shadow: 0 -4px 32px rgba(0,0,0,.25);
      display: none; /* affiché par JS si pas de choix enregistré */
    }
    #cookie-banner.show { display: block; }
    .cookie-inner {
      max-width: 1080px; margin: 0 auto;
      display: flex; align-items: center; justify-content: space-between;
      gap: 20px; flex-wrap: wrap;
    }
    .cookie-text { font-size: .85rem; line-height: 1.6; flex: 1; min-width: 240px; }
    .cookie-text a { color: var(--axeo-orange); text-decoration: underline; }
    .cookie-text strong { color: var(--white); }
    .cookie-btns { display: flex; gap: 10px; flex-wrap: wrap; flex-shrink: 0; }
    .ck-accept {
      background: var(--axeo-orange); color: var(--white);
      border: none; border-radius: 50px; padding: 10px 22px;
      font-family: var(--ff-head); font-weight: 800; font-size: .88rem;
      cursor: pointer; transition: background .2s;
    }
    .ck-accept:hover { background: var(--axeo-orange-dk); }
    .ck-refuse {
      background: transparent; color: rgba(255,255,255,.6);
      border: 1px solid rgba(255,255,255,.2); border-radius: 50px;
      padding: 10px 22px; font-family: var(--ff-head);
      font-weight: 600; font-size: .88rem; cursor: pointer; transition: all .2s;
    }
    .ck-refuse:hover { border-color: rgba(255,255,255,.5); color: var(--white); }
    @media (max-width: 500px) {
      .cookie-btns { width: 100%; }
      .ck-accept, .ck-refuse { flex: 1; text-align: center; }
    }

    /* ═══ TOPBAR ═══════════════════════════════════════════════ */
    .topbar {
      background: var(--axeo-gray); padding: 9px 0;
      font-family: var(--ff-head); font-size: .8rem;
      color: rgba(255,255,255,.65);
    }
    .topbar .container { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px; }
    .topbar a { color: var(--axeo-orange); font-weight: 700; transition: color .2s; }
    .topbar a:hover { color: #ffb840; }

    /* ═══ HEADER ════════════════════════════════════════════════ */
    .site-header {
      position: sticky; top: 0; z-index: 100;
      background: var(--white);
      border-bottom: 2px solid var(--axeo-orange-lt);
      padding: 12px 0;
      box-shadow: var(--shadow-sm);
    }
    .site-header .container { display: flex; align-items: center; justify-content: space-between; gap: 16px; }
    .logo-wrap img { height: 52px; width: auto; }
    .logo-location {
      font-family: var(--ff-head); font-size: .72rem; font-weight: 700;
      color: var(--axeo-orange); text-transform: uppercase; letter-spacing: .06em;
      margin-top: 2px; text-align: center;
    }
    .header-tel {
      font-family: var(--ff-head); font-weight: 800;
      font-size: 1.2rem; color: var(--axeo-gray);
      display: flex; align-items: center; gap: 6px;
    }
    .header-tel::before { content: "📞"; }
    @media (max-width: 580px) { .header-tel { display: none; } }

    /* ═══ HERO ══════════════════════════════════════════════════ */
    .hero {
      background: linear-gradient(135deg, #FFF8EE 0%, #FFF3DC 50%, #FFF8EE 100%);
      padding: 72px 0 0; position: relative; overflow: hidden;
    }
    .hero::before {
      content: ''; position: absolute; top: -60px; right: -100px;
      width: 480px; height: 480px; border-radius: 50%;
      background: radial-gradient(circle, rgba(242,148,0,.10) 0%, transparent 70%);
      pointer-events: none;
    }
    .hero .container {
      position: relative; z-index: 1;
      display: grid; grid-template-columns: 1fr 380px;
      gap: 48px; align-items: end;
    }
    @media (max-width: 860px) { .hero .container { grid-template-columns: 1fr; } .hero-card { display: none; } }

    .hero-left { padding-bottom: 56px; }
    .hero-left > * { opacity: 0; animation: fadeUp .5s var(--ease) forwards; }
    .hero-left > *:nth-child(1) { animation-delay: .05s; }
    .hero-left > *:nth-child(2) { animation-delay: .15s; }
    .hero-left > *:nth-child(3) { animation-delay: .25s; }
    .hero-left > *:nth-child(4) { animation-delay: .35s; }
    .hero-left > *:nth-child(5) { animation-delay: .45s; }

    .hero h1 {
      font-family: var(--ff-head); font-weight: 800;
      font-size: clamp(1.9rem, 4.5vw, 2.8rem);
      color: var(--axeo-gray); line-height: 1.12;
      margin: 12px 0 18px;
    }
    .hero h1 span { color: var(--axeo-orange); }
    .hero-sub { font-size: 1rem; color: var(--axeo-gray-md); max-width: 500px; margin-bottom: 26px; }

    .hero-bullets { list-style: none; margin-bottom: 32px; display: flex; flex-direction: column; gap: 11px; }
    .hero-bullets li { display: flex; align-items: flex-start; gap: 11px; font-size: .93rem; }
    .hb-icon {
      width: 32px; height: 32px; border-radius: 8px;
      background: var(--axeo-orange-lt);
      display: flex; align-items: center; justify-content: center;
      font-size: 1rem; flex-shrink: 0; margin-top: 1px;
    }
    .hb-text strong { display: block; font-weight: 700; color: var(--axeo-gray); font-family: var(--ff-head); }
    .hb-text span   { font-size: .84rem; color: var(--axeo-gray-md); }
    .hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; }

    /* ═══ CARTE PREUVE SOCIALE HERO ════════════════════════════ */
    .hero-card {
      background: var(--axeo-gray); border-radius: var(--radius) var(--radius) 0 0;
      padding: 32px 28px 36px;
      opacity: 0; animation: fadeUp .6s .5s var(--ease) forwards;
      align-self: flex-end;
    }
    .hero-card-top { display: flex; align-items: center; gap: 10px; margin-bottom: 20px; }
    .hero-card-emoji { font-size: 2.4rem; }
    .hero-card-rating .stars { color: var(--axeo-orange); font-size: 1rem; letter-spacing: 2px; }
    .hero-card-rating strong { color: var(--white); font-family: var(--ff-head); font-size: 1rem; display: block; }
    .hero-card-rating span   { color: rgba(255,255,255,.5); font-size: .78rem; }
    .mini-review {
      background: rgba(255,255,255,.07); border-radius: 10px;
      padding: 14px 16px; border-left: 3px solid var(--axeo-orange);
    }
    .mini-review p { font-size: .86rem; font-style: italic; color: rgba(255,255,255,.8); margin-bottom: 8px; line-height: 1.6; }
    .mini-review-meta { font-size: .75rem; color: rgba(255,255,255,.45); }
    .mini-review-tag {
      display: inline-block; margin-top: 8px;
      background: rgba(242,148,0,.2); color: var(--axeo-orange);
      font-size: .74rem; font-weight: 700; padding: 3px 10px; border-radius: 5px;
    }
    .hero-card-badges { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 16px; }
    .badge {
      background: rgba(255,255,255,.08); color: rgba(255,255,255,.7);
      font-family: var(--ff-head); font-size: .72rem; font-weight: 700;
      padding: 4px 12px; border-radius: 20px;
    }

    /* ═══ TRUST BAR ════════════════════════════════════════════ */
    .trust-bar { background: var(--white); border-top: 3px solid var(--axeo-orange); padding: 16px 0; }
    .trust-bar .container { display: flex; justify-content: space-around; align-items: center; flex-wrap: wrap; gap: 12px; }
    .trust-item { display: flex; align-items: center; gap: 8px; font-family: var(--ff-head); font-size: .83rem; font-weight: 700; color: var(--axeo-gray); }
    .trust-item span { font-size: 1.2rem; }

    /* ═══ FORMULES ══════════════════════════════════════════════ */
    .formules { background: var(--axeo-gray-lt); }
    .formules-grid {
      display: grid; grid-template-columns: repeat(3, 1fr);
      gap: 18px; margin-top: 44px;
    }
    @media (max-width: 700px) { .formules-grid { grid-template-columns: 1fr; } }

    .f-card {
      background: var(--white); border-radius: var(--radius);
      padding: 28px 22px; border: 2px solid transparent;
      transition: all .25s var(--ease); position: relative;
    }
    .f-card:hover { border-color: var(--axeo-orange); box-shadow: var(--shadow-md); transform: translateY(-3px); }
    .f-card.featured { border-color: var(--axeo-orange); box-shadow: var(--shadow-md); }
    .f-best {
      position: absolute; top: -13px; left: 50%; transform: translateX(-50%);
      background: var(--axeo-orange); color: var(--white);
      font-family: var(--ff-head); font-size: .7rem; font-weight: 800;
      padding: 4px 16px; border-radius: 20px; white-space: nowrap;
      text-transform: uppercase; letter-spacing: .06em;
    }
    .f-icon { font-size: 2.2rem; margin-bottom: 12px; }
    .f-card h3 { font-family: var(--ff-head); font-weight: 800; font-size: 1.15rem; color: var(--axeo-gray); margin-bottom: 6px; }
    .f-price { font-family: var(--ff-head); font-weight: 800; font-size: 1.7rem; color: var(--axeo-orange); margin-bottom: 2px; }
    .f-price small { font-size: .85rem; font-weight: 400; color: var(--axeo-gray-md); }
    .f-sub { font-size: .78rem; color: var(--axeo-gray-md); margin-bottom: 16px; }
    .f-list { list-style: none; display: flex; flex-direction: column; gap: 8px; }
    .f-list li { font-size: .87rem; display: flex; align-items: flex-start; gap: 8px; }
    .f-list li::before { content: "✓"; color: var(--axeo-orange); font-weight: 800; flex-shrink: 0; }

    /* ═══ RÉGIMES ═══════════════════════════════════════════════ */
    .regimes { background: var(--white); }
    .regimes-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 12px; margin-top: 36px; }
    .r-chip {
      background: var(--axeo-orange-lt); border-radius: 12px;
      padding: 18px 14px; text-align: center;
      border: 1.5px solid transparent; transition: all .2s var(--ease);
    }
    .r-chip:hover { border-color: var(--axeo-orange); box-shadow: var(--shadow-sm); }
    .r-chip .re { font-size: 1.8rem; margin-bottom: 8px; }
    .r-chip p { font-family: var(--ff-head); font-size: .8rem; font-weight: 700; color: var(--axeo-gray); line-height: 1.3; }

    /* ═══ PROCESSUS ═════════════════════════════════════════════ */
    .process { background: var(--axeo-gray); }
    .process .sec-h2 { color: var(--white); }
    .process .sec-intro { color: rgba(255,255,255,.6); }
    .process-steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0; margin-top: 44px; position: relative; }
    @media (max-width: 640px) { .process-steps { grid-template-columns: 1fr; } .process-steps::before { display: none; } }
    .process-steps::before {
      content: ''; position: absolute; top: 28px; left: 16.5%; right: 16.5%;
      height: 2px; background: linear-gradient(90deg, rgba(242,148,0,.2), var(--axeo-orange), rgba(242,148,0,.2));
    }
    .pstep { text-align: center; padding: 0 20px; position: relative; z-index: 1; }
    .pstep-num {
      width: 56px; height: 56px; border-radius: 50%;
      background: var(--axeo-orange); color: var(--white);
      font-family: var(--ff-head); font-weight: 800; font-size: 1.4rem;
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 18px; box-shadow: 0 4px 16px rgba(242,148,0,.4);
    }
    .pstep h3 { font-family: var(--ff-head); font-size: 1.05rem; font-weight: 800; color: var(--white); margin-bottom: 8px; }
    .pstep p  { font-size: .87rem; color: rgba(255,255,255,.6); line-height: 1.6; }

    /* ═══ ZONE ══════════════════════════════════════════════════ */
    .zone { background: var(--axeo-gray-lt); }
    .zone-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 44px; margin-top: 36px; }
    @media (max-width: 640px) { .zone-grid { grid-template-columns: 1fr; } }
    .zone-pills { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 20px; }
    .z-pill { background: var(--white); border: 1.5px solid rgba(242,148,0,.25); border-radius: 20px; padding: 6px 14px; font-family: var(--ff-head); font-size: .8rem; font-weight: 700; color: var(--axeo-gray); }
    .horaires-card { background: var(--axeo-gray); border-radius: var(--radius); padding: 26px; }
    .horaires-card h4 { font-family: var(--ff-head); font-weight: 800; font-size: 1.1rem; color: var(--white); margin-bottom: 18px; }
    .h-row { display: flex; justify-content: space-between; padding: 9px 0; border-bottom: 1px solid rgba(255,255,255,.07); font-size: .88rem; }
    .h-row:last-child { border: none; }
    .h-day { color: rgba(255,255,255,.55); }
    .h-time { font-weight: 700; color: var(--axeo-orange); font-family: var(--ff-head); }
    .map-ph { background: var(--white); border-radius: 12px; height: 220px; border: 2px dashed rgba(242,148,0,.3); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px; color: var(--axeo-gray-md); font-size: .88rem; margin-bottom: 16px; }

    /* ═══ TÉMOIGNAGES ═══════════════════════════════════════════ */
    .testi { background: var(--white); }
    .testi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 18px; margin-top: 36px; }
    .t-card { background: var(--axeo-gray-lt); border-radius: var(--radius); padding: 26px; border: 2px solid transparent; transition: border-color .2s; position: relative; overflow: hidden; }
    .t-card::before { content: '"'; position: absolute; top: 8px; right: 16px; font-family: Georgia,serif; font-size: 5rem; color: rgba(242,148,0,.08); line-height: 1; }
    .t-card:hover { border-color: var(--axeo-orange-lt); }
    .t-stars { color: var(--axeo-orange); font-size: .9rem; margin-bottom: 10px; }
    .t-text { font-size: .92rem; font-style: italic; color: var(--axeo-gray); line-height: 1.7; margin-bottom: 14px; }
    .t-author { font-family: var(--ff-head); font-weight: 800; font-size: .84rem; color: var(--axeo-gray); }
    .t-meta { font-size: .76rem; color: var(--axeo-gray-md); margin-bottom: 8px; }
    .t-result { display: inline-block; background: var(--axeo-orange-lt); color: var(--axeo-orange-dk); font-family: var(--ff-head); font-size: .74rem; font-weight: 800; padding: 3px 10px; border-radius: 5px; }

    /* ═══ FAQ ════════════════════════════════════════════════════ */
    .faq { background: var(--axeo-gray-lt); }
    .faq-list { margin-top: 36px; display: flex; flex-direction: column; gap: 10px; max-width: 760px; }
    .faq-item { background: var(--white); border-radius: 10px; border: 1.5px solid rgba(242,148,0,.15); overflow: hidden; }
    .faq-btn { width: 100%; padding: 17px 18px; text-align: left; background: none; border: none; cursor: pointer; font-family: var(--ff-head); font-weight: 700; font-size: .93rem; color: var(--axeo-gray); display: flex; justify-content: space-between; align-items: center; gap: 10px; transition: color .2s; }
    .faq-btn:hover { color: var(--axeo-orange); }
    .faq-icon { font-size: 1.2rem; transition: transform .25s; flex-shrink: 0; color: var(--axeo-orange); }
    .faq-body { max-height: 0; overflow: hidden; transition: max-height .35s ease, padding .25s; padding: 0 18px; font-size: .9rem; color: var(--axeo-gray-md); line-height: 1.75; }
    .faq-item.open .faq-body { max-height: 240px; padding-bottom: 16px; }
    .faq-item.open .faq-icon { transform: rotate(45deg); }

    /* ═══ FORMULAIRE DE RAPPEL ═══════════════════════════════════ */
    .rappel { background: var(--axeo-orange); }
    .rappel .sec-h2 { color: var(--white); }
    .rappel .eyebrow { color: rgba(255,255,255,.8); }
    .rappel-sub { color: rgba(255,255,255,.8); font-size: .97rem; margin-bottom: 32px; }
    .rappel-grid { display: grid; grid-template-columns: 1fr 400px; gap: 60px; align-items: start; }
    @media (max-width: 800px) { .rappel-grid { grid-template-columns: 1fr; gap: 32px; } }
    .rappel-feats { list-style: none; display: flex; flex-direction: column; gap: 13px; }
    .rappel-feats li { display: flex; align-items: center; gap: 10px; font-size: .92rem; color: rgba(255,255,255,.9); }
    .rf-ck { width: 24px; height: 24px; border-radius: 50%; background: rgba(255,255,255,.2); color: var(--white); font-weight: 800; font-size: .82rem; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }

    .lead-form { background: var(--white); border-radius: var(--radius); padding: 32px; box-shadow: var(--shadow-lg); }
    .lead-form h3 { font-family: var(--ff-head); font-weight: 800; font-size: 1.2rem; color: var(--axeo-gray); margin-bottom: 6px; }
    .lead-form .fi { font-size: .86rem; color: var(--axeo-gray-md); margin-bottom: 22px; }
    .fg { margin-bottom: 14px; }
    .fg label { display: block; font-family: var(--ff-head); font-size: .84rem; font-weight: 700; color: var(--axeo-gray); margin-bottom: 6px; }
    .fg input, .fg select { width: 100%; padding: 13px 15px; border: 1.5px solid rgba(61,61,61,.18); border-radius: 10px; font-family: var(--ff-body); font-size: 1rem; color: var(--axeo-gray); background: var(--white); transition: border-color .2s; outline: none; appearance: none; }
    .fg input:focus, .fg select:focus { border-color: var(--axeo-orange); }
    .form-btn { width: 100%; padding: 15px; border: none; border-radius: 50px; background: var(--axeo-orange); color: var(--white); font-family: var(--ff-head); font-weight: 800; font-size: 1rem; cursor: pointer; transition: all .25s var(--ease); margin-top: 6px; box-shadow: 0 4px 16px rgba(242,148,0,.3); }
    .form-btn:hover { background: var(--axeo-orange-dk); transform: translateY(-2px); }
    .form-legal { font-size: .72rem; color: var(--axeo-gray-md); margin-top: 10px; text-align: center; line-height: 1.5; }

    /* ═══ FOOTER ════════════════════════════════════════════════ */
    .site-footer { background: var(--axeo-gray); padding: 48px 0 20px; }
    .footer-grid { display: grid; grid-template-columns: 1.5fr 1fr 1fr; gap: 36px; margin-bottom: 36px; }
    @media (max-width: 640px) { .footer-grid { grid-template-columns: 1fr; } }
    .footer-logo img { height: 44px; width: auto; filter: brightness(0) invert(1); margin-bottom: 14px; }
    .footer-desc { font-size: .84rem; color: rgba(255,255,255,.45); line-height: 1.7; margin-bottom: 16px; }
    .footer-nap span { display: block; font-size: .82rem; color: rgba(255,255,255,.4); margin-bottom: 4px; }
    .footer-nap a { color: var(--axeo-orange); font-weight: 700; font-size: .9rem; }
    .footer-col h4 { font-family: var(--ff-head); font-weight: 800; font-size: .86rem; color: var(--white); margin-bottom: 14px; padding-bottom: 8px; border-bottom: 1px solid rgba(255,255,255,.07); }
    .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 7px; }
    .footer-col ul li a { font-size: .83rem; color: rgba(255,255,255,.4); transition: color .2s; }
    .footer-col ul li a:hover { color: var(--axeo-orange); }
    .footer-bottom { border-top: 1px solid rgba(255,255,255,.06); padding-top: 16px; display: flex; justify-content: space-between; flex-wrap: wrap; gap: 8px; }
    .footer-bottom span { font-size: .77rem; color: rgba(255,255,255,.25); font-family: var(--ff-head); }
    .footer-bottom a { color: rgba(255,255,255,.4); text-decoration: underline; }

    /* ═══ STICKY MOBILE ══════════════════════════════════════════ */
    .sticky-cta { display: none; position: fixed; bottom: 0; left: 0; right: 0; z-index: 200; padding: 12px 20px; background: var(--axeo-orange); box-shadow: 0 -4px 20px rgba(0,0,0,.15); }
    .sticky-cta a { display: flex; align-items: center; justify-content: center; gap: 8px; color: var(--white); font-family: var(--ff-head); font-weight: 800; font-size: 1rem; }
    @media (max-width: 768px) { .sticky-cta { display: block; } body { padding-bottom: 56px; } }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }
  </style>
</head>
<body>

