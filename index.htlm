          </p>
          <!-- ⚠ NAP identique — microdata -->
          <div class="footer-nap" itemscope itemtype="https://schema.org/LocalBusiness">
            <span itemprop="name" style="display:none">AXEO Services Toulouse</span>
            <span>📍 <span itemprop="address">12 Allée Jean Jaurès, 31000 Toulouse</span></span>
            <a href="tel:+33500000000" itemprop="telephone" onclick="trackCall('footer')">📞 05 00 00 00 00</a>
            <span>🕗 Lun–Ven 8h–19h · Sam 8h–13h</span>
          </div>
        </div>

        <div class="footer-col">
          <h4>Nos formules</h4>
          <ul>
            <li><a href="#offre">Formule Essentiel</a></li>
            <li><a href="#offre">Formule Confort</a></li>
            <li><a href="#offre">Formule Premium</a></li>
            <li><a href="#regimes">Régimes spéciaux</a></li>
          </ul>
        </div>

        <div class="footer-col">
          <h4>Informations utiles</h4>
