  <!-- ══════════════════════════════════════════════
       STICKY CTA MOBILE
       ⚠ Affiché uniquement ≤768px
  ══════════════════════════════════════════════ -->
  <div class="sticky-cta" role="complementary" aria-label="Appel rapide">
    <a href="tel:+33500000000" onclick="trackCall('sticky_mobile')">
      <span style="font-size:1.3rem;">📞</span>
      Appeler AXEO Toulouse — Gratuit
    </a>
  </div>

  <!-- ══════════════════════════════════════════════
       JS — FAQ accordion + form handling
       ⚠ En bas de page — pas besoin de defer
  ══════════════════════════════════════════════ -->
  <script>
    // ─── FAQ accordion ─────────────────────────────
    document.querySelectorAll('.faq-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const item   = btn.closest('.faq-item');
        const isOpen = item.classList.contains('open');
        document.querySelectorAll('.faq-item').forEach(i => {
          i.classList.remove('open');
          i.querySelector('.faq-btn').setAttribute('aria-expanded', 'false');
        });
        if (!isOpen) {
          item.classList.add('open');
          btn.setAttribute('aria-expanded', 'true');
        }
      });
    });

    // ─── Form submit ────────────────────────────────
    function handleFormSubmit() {
      const prenom = document.getElementById('prenom').value.trim();
      const tel    = document.getElementById('tel').value.trim();
      if (!prenom || !tel) {
        alert('Merci de renseigner votre prénom et votre téléphone.');
        return;
      }

      // ⚠ Tracking GA4 — macro-conversion
      trackForm();

      // ⚠ Webhook Make / Zapier / n8n — décommenter et remplacer l'URL
      // fetch('https://hook.make.com/XXXXXXXXXXXXXXXX', {
      //   method: 'POST',
      //   headers: { 'Content-Type': 'application/json' },
      //   body: JSON.stringify({
      //     prenom,
      //     tel,
      //     situation: document.getElementById('situation').value,
      //     service: 'livraison-repas-senior',
      //     ville: 'Toulouse',
      //     source: 'landing-page'
      //   })
      // });

      // UX post-submit
      document.querySelector('.lead-form').innerHTML = `
        <div style="text-align:center;padding:48px 20px;">
          <div style="font-size:3.5rem;margin-bottom:18px;">✅</div>
          <h3 style="font-family:var(--ff-head);color:var(--sage-dark);margin-bottom:10px;">
            Merci ${prenom} !
          </h3>
          <p style="color:var(--text-muted);font-size:.95rem;line-height:1.7;">
            Un conseiller AXEO vous rappelle sous <strong>2 heures</strong><br>
            au numéro indiqué pour vous présenter la formule adaptée.
          </p>
        </div>
      `;
    }
  </script>

</body>
</html>
