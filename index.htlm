  <!-- ══ FORMULES ══════════════════════════════════════════════════ -->
  <section class="formules" id="formules">
    <div class="container">
      <span class="eyebrow">Nos formules</span>
      <h2 class="sec-h2">Choisissez la formule <span>adaptée</span><br>à votre proche</h2>
      <p class="sec-intro">Toutes les formules incluent la livraison, l'emballage isotherme et le suivi personnalisé. Prix nets après crédit d'impôt 50%.</p>
      <div class="formules-grid">
        <div class="f-card">
          <div class="f-icon">🥗</div>
          <h3>Essentiel</h3>
