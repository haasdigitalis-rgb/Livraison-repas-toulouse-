  <!-- ══ STICKY MOBILE ══════════════════════════════════════════════ -->
  <div class="sticky-cta">
    <a href="tel:+33531220021" onclick="trackCall('sticky_mobile')">
      <span style="font-size:1.3rem">📞</span> Appeler AXEO Toulouse — Gratuit
    </a>
  </div>

  <script>
    // ── Cookie banner ─────────────────────────────
    function showBannerIfNeeded() {
      if (!localStorage.getItem('axeo_consent')) {
        document.getElementById('cookie-banner').classList.add('show');
      }
    }
    function acceptCookies() {
      grantConsent();
      document.getElementById('cookie-banner').classList.remove('show');
    }
    function refuseCookies() {
      denyConsent();
      document.getElementById('cookie-banner').classList.remove('show');
    }
    showBannerIfNeeded();

    // ── FAQ ───────────────────────────────────────
    document.querySelectorAll('.faq-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const item = btn.closest('.faq-item');
        const isOpen = item.classList.contains('open');
        document.querySelectorAll('.faq-item').forEach(i => { i.classList.remove('open'); i.querySelector('.faq-btn').setAttribute('aria-expanded','false'); });
        if (!isOpen) { item.classList.add('open'); btn.setAttribute('aria-expanded','true'); }
      });
    });

    // ── Scroll 50% ────────────────────────────────
    let scroll50Sent = false;
    window.addEventListener('scroll', () => {
      if (scroll50Sent) return;
      const pct = window.scrollY / (document.body.scrollHeight - window.innerHeight) * 100;
      if (pct >= 50) { if (typeof gtag !== 'undefined') gtag('event','scroll_50',{event_category:'engagement'}); scroll50Sent = true; }
    }, { passive: true });

    // ── GA4 client_id ─────────────────────────────
    function getGA4ClientId() {
      const m = document.cookie.match(/(?:^|;\s*)_ga=GA\d+\.\d+\.(\d+\.\d+)/);
      return m ? m[1] : null;
    }

    // ── Form submit ───────────────────────────────
    function handleFormSubmit() {
      const prenom = document.getElementById('prenom').value.trim();
      const tel    = document.getElementById('tel').value.trim();
      if (!prenom || !tel) { alert('Merci de renseigner votre prénom et votre téléphone.'); return; }
      trackForm();
      // ⚠ Décommenter et remplacer l'URL par ton webhook Make
      // fetch('https://hook.make.com/XXXXXXXXXXXXXXXX', {
      //   method: 'POST',
      //   headers: { 'Content-Type': 'application/json' },
      //   body: JSON.stringify({ prenom, tel, situation: document.getElementById('situation').value, service: 'livraison-repas-senior', ville: 'toulouse', source: 'landing-page', ga_client_id: getGA4ClientId() })
      // });
      document.querySelector('.lead-form').innerHTML = '<div style="text-align:center;padding:48px 20px;"><div style="font-size:3.5rem;margin-bottom:16px;">✅</div><h3 style="font-family:var(--ff-head);font-weight:800;color:var(--axeo-gray);margin-bottom:10px;">Merci ' + prenom + ' !</h3><p style="color:var(--axeo-gray-md);">Un conseiller AXEO vous rappelle sous <strong>2 heures</strong> au numéro indiqué.</p></div>';
    }
  </script>
</body>
</html>
