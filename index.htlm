<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- ══ TITLE — 57 car. — mot-clé local en tête ══════════════════ -->
  <title>Livraison repas senior Toulouse — AXEO Services à domicile</title>

  <!-- ══ META DESCRIPTION — 158 car. ══════════════════════════════ -->
  <meta name="description" content="Livraison de repas équilibrés pour seniors à Toulouse. Repas chauds ou froids, livrés à domicile chaque jour. Devis gratuit. Aide fiscale 50%. AXEO Services." />

  <!-- ══ SCHEMA.ORG LocalBusiness + contactPoint ═══════════════════
       ⚠ NAP identique : page / footer / GBP / annuaires
  ════════════════════════════════════════════════════════════════ -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "AXEO Services Toulouse — Livraison repas senior",
    "image": "https://axeo-toulouse.fr/repas-senior-hero.webp",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "12 Allée Jean Jaurès",
      "addressLocality": "Toulouse",
      "postalCode": "31000",
      "addressCountry": "FR"
    },
    "telephone": "+33500000000",
    "areaServed": "Toulouse et agglomération",
    "url": "https://axeo-toulouse.fr/livraison-repas-senior",
    "priceRange": "€€",
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": "+33500000000",
      "contactType": "customer service",
      "areaServed": "FR",
      "availableLanguage": "French"
    },
    "openingHoursSpecification": [
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
        "opens": "08:00",
        "closes": "19:00"
      },
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Saturday","Sunday"],
        "opens": "09:00",
        "closes": "13:00"
      }
    ]
  }
  </script>

  <!-- ══ FAQ SCHEMA — boost SEO rich snippets ═══════════════════════ -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Quel est le prix d'une livraison de repas à domicile pour senior à Toulouse ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Nos repas sont proposés à partir de 8,50€ par repas livré. Grâce au crédit d'impôt de 50%, le coût réel descend à environ 4,25€ par repas. Des aides complémentaires (APA, CARSAT, CCAS) peuvent s'appliquer selon votre situation."
        }
      },
      {
        "@type": "Question",
        "name": "Les repas sont-ils adaptés aux régimes alimentaires spéciaux ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Oui. Nous proposons des menus sans sel, mixés, diabétiques, sans porc et adaptés aux troubles de la déglutition. Un conseiller évalue vos besoins lors du premier contact."
        }
      }
    ]
  }
  </script>

  <!-- ══ GA4 — remplacer G-XXXXXXXX ═════════════════════════════════ -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXX"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-XXXXXXXX');

    /* ⚠ Événements conversion Google Ads :
       – tel_click  → micro-conversion
       – form_submit → macro-conversion (lead qualifié)
    */
    function trackCall(label) {
      gtag('event', 'tel_click', { event_category: 'contact', event_label: label || 'cta' });
    }
    function trackForm() {
      gtag('event', 'form_submit', { event_category: 'lead', event_label: 'rappel_repas_senior' });
    }
  </script>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">

  <style>
    /* ══════════════════════════════════════════════
       TOKENS — palette "confort & chaleur"
       Vert sauge + terre cuite + crème — évoque
       nutrition, soin, authenticité (vs bleu corporate)
    ══════════════════════════════════════════════ */
    :root {
      --sage:        #4A7C6F;
      --sage-dark:   #2D5248;
      --sage-light:  #EBF3F0;
      --terracotta:  #C4623A;
      --terra-light: #FDF1EB;
      --cream:       #FAF7F2;
      --text-main:   #1E1E1E;
      --text-muted:  #6B7280;
      --white:       #FFFFFF;
      --radius-sm:   8px;
      --radius-md:   16px;
      --radius-lg:   24px;
      --shadow-sm:   0 2px 12px rgba(45,82,72,.08);
      --shadow-md:   0 6px 28px rgba(45,82,72,.14);
      --shadow-lg:   0 16px 48px rgba(45,82,72,.18);
      --ff-head:     'DM Serif Display', Georgia, serif;
      --ff-body:     'DM Sans', sans-serif;
      --ease:        cubic-bezier(.4,0,.2,1);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: var(--ff-body);
      color: var(--text-main);
      background: var(--cream);
      line-height: 1.65;
      overflow-x: hidden;
    }
    img { max-width: 100%; height: auto; display: block; }
    a   { color: inherit; text-decoration: none; }

    /* ══════════════ UTILITAIRES ══════════════ */
    .container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }
    section    { padding: 80px 0; }

    .btn-primary {
      display: inline-flex; align-items: center; gap: 9px;
      background: var(--terracotta); color: var(--white);
      font-family: var(--ff-body); font-weight: 600; font-size: 1rem;
      padding: 15px 30px; border-radius: 50px; border: none; cursor: pointer;
      transition: all .25s var(--ease);
      box-shadow: 0 4px 20px rgba(196,98,58,.32);
      text-decoration: none; white-space: nowrap;
    }
    .btn-primary:hover {
      background: #ad5430;
      transform: translateY(-2px);
      box-shadow: 0 8px 28px rgba(196,98,58,.42);
    }
    .btn-ghost {
      display: inline-flex; align-items: center; gap: 8px;
      background: transparent; color: var(--sage-dark);
      font-family: var(--ff-body); font-weight: 600; font-size: .95rem;
      padding: 14px 26px; border-radius: 50px;
      border: 2px solid rgba(45,82,72,.3);
      cursor: pointer; transition: all .25s var(--ease); text-decoration: none;
    }
    .btn-ghost:hover { background: var(--sage-dark); color: var(--white); border-color: var(--sage-dark); }
    .pill {
      display: inline-block;
      background: var(--sage-light); color: var(--sage-dark);
      font-family: var(--ff-body); font-size: .75rem; font-weight: 600;
      padding: 5px 13px; border-radius: 20px;
      letter-spacing: .06em; text-transform: uppercase;
    }
    .pill-terra {
      background: var(--terra-light); color: var(--terracotta);
    }
    .eyebrow {
      font-family: var(--ff-body); font-size: .78rem; font-weight: 600;
      color: var(--terracotta); text-transform: uppercase; letter-spacing: .1em;
      margin-bottom: 10px; display: block;
    }
    .section-h2 {
      font-family: var(--ff-head); font-size: clamp(1.7rem, 3.5vw, 2.4rem);
      color: var(--sage-dark); line-height: 1.18; margin-bottom: 16px;
    }
    .section-h2 em { color: var(--terracotta); font-style: italic; }
    .section-intro { font-size: 1rem; color: var(--text-muted); max-width: 560px; }

    /* ══════════════════════════════════════════════
       BLOC 1 — TOPBAR NAP
       ⚠ Format E.164 obligatoire pour schema.org
    ══════════════════════════════════════════════ */
    .topbar {
      background: var(--sage-dark);
      padding: 9px 0;
      font-family: var(--ff-body); font-size: .82rem;
      color: rgba(255,255,255,.7);
    }
    .topbar .container {
      display: flex; justify-content: space-between;
      align-items: center; flex-wrap: wrap; gap: 8px;
    }
    .topbar a { color: #A8D5C6; font-weight: 600; transition: color .2s; }
    .topbar a:hover { color: var(--white); }

    /* ══════════════════════════════════════════════
       BLOC 2 — HEADER sticky
       ⚠ CTA "Appeler" visible AVANT ligne de flottaison
    ══════════════════════════════════════════════ */
    .site-header {
      position: sticky; top: 0; z-index: 100;
      background: var(--white);
      border-bottom: 1px solid rgba(45,82,72,.1);
      padding: 14px 0;
      box-shadow: var(--shadow-sm);
    }
    .site-header .container {
      display: flex; align-items: center;
      justify-content: space-between; gap: 16px;
    }
    .logo {
      display: flex; align-items: center; gap: 11px;
    }
    .logo-badge {
      width: 42px; height: 42px; border-radius: 10px;
      background: var(--sage); display: flex; align-items: center;
      justify-content: center; font-size: 1.2rem; flex-shrink: 0;
    }
    .logo-name { font-family: var(--ff-body); font-weight: 600; font-size: 1rem; color: var(--sage-dark); }
    .logo-tag  { font-size: .72rem; color: var(--text-muted); }
    .header-tel {
      font-family: var(--ff-body); font-weight: 700;
      font-size: 1.2rem; color: var(--sage-dark);
    }
    @media (max-width: 580px) { .header-tel { display: none; } }

    /* ══════════════════════════════════════════════
       BLOC 3 — HERO
       ⚠ H1 localisé + mot-clé service
       ⚠ 3 bullets concrètes au-dessus de la ligne
       ⚠ Preuve sociale immédiate
       ⚠ LCP : hero sans image lourde, fond CSS pur
    ══════════════════════════════════════════════ */
    .hero {
      background: var(--cream);
      padding: 72px 0 0;
      position: relative;
      overflow: hidden;
    }
    /* Décoration géométrique — fond texturé sans image externe */
    .hero::before {
      content: '';
      position: absolute; top: -80px; right: -120px;
      width: 600px; height: 600px; border-radius: 50%;
      background: radial-gradient(circle, rgba(74,124,111,.12) 0%, transparent 70%);
      pointer-events: none;
    }
    .hero::after {
      content: '';
      position: absolute; bottom: 0; left: -80px;
      width: 400px; height: 400px; border-radius: 50%;
      background: radial-gradient(circle, rgba(196,98,58,.07) 0%, transparent 70%);
      pointer-events: none;
    }
    .hero .container {
      position: relative; z-index: 1;
      display: grid; grid-template-columns: 1fr 400px;
      gap: 48px; align-items: end;
    }
    @media (max-width: 860px) {
      .hero .container { grid-template-columns: 1fr; }
      .hero-visual { display: none; }
    }

    .hero-left { padding-bottom: 56px; }
    .hero-left > * { opacity: 0; animation: fadeUp .55s var(--ease) forwards; }
    .hero-left > *:nth-child(1) { animation-delay: .05s; }
    .hero-left > *:nth-child(2) { animation-delay: .15s; }
    .hero-left > *:nth-child(3) { animation-delay: .25s; }
    .hero-left > *:nth-child(4) { animation-delay: .35s; }
    .hero-left > *:nth-child(5) { animation-delay: .45s; }

    /* ⚠ H1 — 1 par page, mot-clé + localisation */
    .hero h1 {
      font-family: var(--ff-head);
      font-size: clamp(2rem, 4.5vw, 3rem);
      color: var(--sage-dark); line-height: 1.12;
      margin: 12px 0 20px;
    }
    .hero h1 span { color: var(--terracotta); }
    .hero-sub {
      font-size: 1.05rem; color: var(--text-muted);
      max-width: 500px; margin-bottom: 28px;
    }

    /* ⚠ 3 bullets ultra-concrètes (délai/zone/prix) */
    .hero-bullets { list-style: none; margin-bottom: 36px; display: flex; flex-direction: column; gap: 12px; }
    .hero-bullets li {
      display: flex; align-items: flex-start; gap: 12px;
      font-size: .95rem; color: var(--text-main);
    }
    .hb-icon {
      width: 32px; height: 32px; border-radius: 8px;
      background: var(--sage-light);
      display: flex; align-items: center; justify-content: center;
      font-size: 1rem; flex-shrink: 0; margin-top: 1px;
    }
    .hb-text strong { display: block; font-weight: 600; color: var(--sage-dark); }
    .hb-text span   { font-size: .86rem; color: var(--text-muted); }

    .hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; }

    /* ══ Carte flottante preuve sociale ══════
       ⚠ Note + avis + 1 mini-cas résultat chiffré
    ════════════════════════════════════════ */
    .hero-visual {
      align-self: flex-end;
      position: relative;
    }
    .hero-plate {
      background: var(--sage-dark);
      border-radius: var(--radius-lg) var(--radius-lg) 0 0;
      padding: 36px 32px 40px;
      opacity: 0; animation: fadeUp .65s .5s var(--ease) forwards;
    }
    .plate-emoji { font-size: 3.5rem; margin-bottom: 20px; display: block; line-height: 1; }
    .plate-title {
      font-family: var(--ff-head); font-size: 1.5rem;
      color: var(--white); margin-bottom: 6px;
    }
    .plate-sub { font-size: .88rem; color: rgba(255,255,255,.6); margin-bottom: 24px; }
    .rating-row { display: flex; align-items: center; gap: 10px; margin-bottom: 20px; }
    .stars { color: #FFC857; font-size: 1rem; letter-spacing: 2px; }
    .rating-score { font-family: var(--ff-body); font-weight: 700; font-size: 1rem; color: var(--white); }
    .rating-count { font-size: .8rem; color: rgba(255,255,255,.5); }
    .mini-review {
      background: rgba(255,255,255,.08); border-radius: var(--radius-sm);
      padding: 14px 16px; border-left: 3px solid var(--terracotta);
    }
    .mini-review p { font-size: .88rem; font-style: italic; color: rgba(255,255,255,.82); margin-bottom: 8px; }
    .mini-review-meta { font-size: .78rem; color: rgba(255,255,255,.5); font-weight: 500; }
    .mini-review-result {
      display: inline-block; margin-top: 8px;
      background: rgba(196,98,58,.25); color: #F4A57B;
      font-size: .75rem; font-weight: 600;
      padding: 3px 10px; border-radius: 4px;
    }

    /* ══════════════════════════════════════════════
       BLOC 4 — TRUST BAR
    ══════════════════════════════════════════════ */
    .trust-bar {
      background: var(--white);
      border-top: 1px solid rgba(45,82,72,.06);
      border-bottom: 1px solid rgba(45,82,72,.06);
      padding: 18px 0;
    }
    .trust-bar .container {
      display: flex; justify-content: space-around;
      align-items: center; flex-wrap: wrap; gap: 14px;
    }
    .trust-item {
      display: flex; align-items: center; gap: 8px;
      font-family: var(--ff-body); font-size: .85rem;
      font-weight: 600; color: var(--sage-dark);
    }
    .trust-item .ti { font-size: 1.2rem; }

    /* ══════════════════════════════════════════════
       BLOC 5 — OFFRE REPAS (le cœur du service)
       ⚠ Spécifique livraison repas senior :
         formules, adaptation régimes, fréquence
    ══════════════════════════════════════════════ */
    .offre { background: var(--white); }
    .offre-grid {
      display: grid; grid-template-columns: repeat(3, 1fr);
      gap: 20px; margin-top: 48px;
    }
    @media (max-width: 700px) { .offre-grid { grid-template-columns: 1fr; } }

    .offre-card {
      border: 1.5px solid rgba(45,82,72,.1);
      border-radius: var(--radius-md); padding: 28px 24px;
      position: relative; transition: all .25s var(--ease);
      background: var(--cream);
    }
    .offre-card:hover {
      border-color: var(--sage);
      box-shadow: var(--shadow-md);
      transform: translateY(-4px);
    }
    .offre-card.featured {
      background: var(--sage-dark); border-color: var(--sage-dark);
    }
    .offre-card.featured h3,
    .offre-card.featured .offre-price,
    .offre-card.featured ul li { color: var(--white) !important; }
    .offre-card.featured .offre-sub { color: rgba(255,255,255,.6); }
    .offre-card.featured .offre-check { color: #A8D5C6; }
    .featured-badge {
      position: absolute; top: -12px; left: 50%; transform: translateX(-50%);
      background: var(--terracotta); color: var(--white);
      font-size: .72rem; font-weight: 700; padding: 4px 14px;
      border-radius: 20px; white-space: nowrap; letter-spacing: .06em;
      text-transform: uppercase;
    }
    .offre-icon { font-size: 2rem; margin-bottom: 12px; }
    .offre-card h3 {
      font-family: var(--ff-head); font-size: 1.2rem;
      color: var(--sage-dark); margin-bottom: 6px;
    }
    .offre-price {
      font-family: var(--ff-body); font-weight: 700; font-size: 1.5rem;
      color: var(--terracotta); margin-bottom: 2px;
    }
    .offre-sub { font-size: .8rem; color: var(--text-muted); margin-bottom: 16px; }
    .offre-list { list-style: none; display: flex; flex-direction: column; gap: 8px; }
    .offre-list li {
      font-size: .88rem; color: var(--text-main);
      display: flex; align-items: flex-start; gap: 8px;
    }
    .offre-check { color: var(--sage); font-weight: 700; flex-shrink: 0; }

    /* ══════════════════════════════════════════════
       BLOC 6 — RÉGIMES SPÉCIAUX (différenciateur clé)
       ⚠ Objection senior : "mon parent a un régime"
    ══════════════════════════════════════════════ */
    .regimes { background: var(--terra-light); }
    .regimes-grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
      gap: 14px; margin-top: 40px;
    }
    .regime-chip {
      background: var(--white); border-radius: var(--radius-sm);
      padding: 18px 16px; text-align: center;
      border: 1px solid rgba(196,98,58,.15);
      transition: all .2s var(--ease);
    }
    .regime-chip:hover { border-color: var(--terracotta); box-shadow: var(--shadow-sm); }
    .regime-chip .re { font-size: 1.8rem; margin-bottom: 8px; }
    .regime-chip p {
      font-family: var(--ff-body); font-size: .82rem;
      font-weight: 600; color: var(--sage-dark); line-height: 1.3;
    }

    /* ══════════════════════════════════════════════
       BLOC 7 — PROCESSUS (3 étapes)
    ══════════════════════════════════════════════ */
    .process { background: var(--cream); }
    .process-steps {
      display: grid; grid-template-columns: repeat(3, 1fr);
      gap: 0; margin-top: 48px; position: relative;
    }
    @media (max-width: 640px) {
      .process-steps { grid-template-columns: 1fr; gap: 20px; }
      .process-steps::before { display: none; }
    }
    .process-steps::before {
      content: '';
      position: absolute; top: 28px; left: 16.5%; right: 16.5%;
      height: 2px; background: linear-gradient(90deg, var(--sage-light), var(--sage), var(--sage-light));
      z-index: 0;
    }
    .pstep { text-align: center; padding: 0 24px; position: relative; z-index: 1; }
    .pstep-num {
      width: 56px; height: 56px; border-radius: 50%;
      background: var(--sage); color: var(--white);
      font-family: var(--ff-head); font-size: 1.3rem;
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 20px; box-shadow: 0 4px 16px rgba(74,124,111,.3);
    }
    .pstep h3 {
      font-family: var(--ff-head); font-size: 1.1rem;
      color: var(--sage-dark); margin-bottom: 8px;
    }
    .pstep p { font-size: .88rem; color: var(--text-muted); line-height: 1.6; }

    /* ══════════════════════════════════════════════
       BLOC 8 — ZONE + HORAIRES LIVRAISON
       ⚠ Signal géo Google + info pratique senior
    ══════════════════════════════════════════════ */
    .zone { background: var(--white); }
    .zone-grid {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 48px; align-items: start; margin-top: 40px;
    }
    @media (max-width: 640px) { .zone-grid { grid-template-columns: 1fr; } }
    .zone-pills { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 24px; }
    .zone-pill {
      background: var(--sage-light); color: var(--sage-dark);
      font-size: .82rem; font-weight: 600; font-family: var(--ff-body);
      padding: 6px 14px; border-radius: 20px;
      border: 1px solid rgba(45,82,72,.12);
    }
    .horaires-card {
      background: var(--sage-dark); border-radius: var(--radius-md);
      padding: 28px; color: var(--white);
    }
    .horaires-card h4 {
      font-family: var(--ff-head); font-size: 1.2rem;
      margin-bottom: 20px; color: var(--white);
    }
    .horaire-row {
      display: flex; justify-content: space-between; align-items: center;
      padding: 10px 0;
      border-bottom: 1px solid rgba(255,255,255,.08);
      font-size: .9rem;
    }
    .horaire-row:last-child { border-bottom: none; }
    .horaire-day { color: rgba(255,255,255,.65); }
    .horaire-time { font-weight: 600; color: #A8D5C6; }
    .map-placeholder {
      background: var(--sage-light); border-radius: var(--radius-md);
      height: 240px; display: flex; flex-direction: column;
      align-items: center; justify-content: center; gap: 10px;
      color: var(--text-muted); font-size: .9rem;
      border: 1.5px dashed rgba(45,82,72,.2);
      margin-bottom: 20px;
    }
    .map-placeholder span { font-size: 2.5rem; }

    /* ══════════════════════════════════════════════
       BLOC 9 — TÉMOIGNAGES
       ⚠ Résultats chiffrés — pas juste "très bien"
    ══════════════════════════════════════════════ */
    .testi { background: var(--cream); }
    .testi-grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 20px; margin-top: 40px;
    }
    .testi-card {
      background: var(--white); border-radius: var(--radius-md);
      padding: 28px; box-shadow: var(--shadow-sm);
      position: relative; overflow: hidden;
    }
    .testi-card::before {
      content: '"';
      position: absolute; top: 8px; right: 18px;
      font-family: var(--ff-head); font-size: 5rem;
      color: rgba(74,124,111,.07); line-height: 1;
    }
    .testi-stars { color: #FFC857; font-size: .95rem; margin-bottom: 12px; }
    .testi-text {
      font-size: .93rem; font-style: italic;
      color: var(--text-main); line-height: 1.7; margin-bottom: 16px;
    }
    .testi-author {
      font-weight: 600; font-size: .85rem; color: var(--sage-dark);
    }
    .testi-info { font-size: .78rem; color: var(--text-muted); margin-bottom: 10px; }
    .testi-result {
      display: inline-block;
      background: var(--sage-light); color: var(--sage-dark);
      font-size: .75rem; font-weight: 700;
      padding: 4px 10px; border-radius: 6px;
    }

    /* ══════════════════════════════════════════════
       BLOC 10 — FAQ (6 questions / objections seniors)
       ⚠ + FAQ schema.org pour rich snippets
    ══════════════════════════════════════════════ */
    .faq { background: var(--white); }
    .faq-list { margin-top: 40px; display: flex; flex-direction: column; gap: 10px; max-width: 780px; }
    .faq-item {
      border: 1.5px solid rgba(45,82,72,.1);
      border-radius: var(--radius-sm); overflow: hidden;
      background: var(--cream);
    }
    .faq-btn {
      width: 100%; padding: 18px 20px; text-align: left;
      background: none; border: none; cursor: pointer;
      font-family: var(--ff-body); font-weight: 600; font-size: .95rem;
      color: var(--sage-dark);
      display: flex; justify-content: space-between; align-items: center; gap: 12px;
      transition: color .2s;
    }
    .faq-btn:hover { color: var(--terracotta); }
    .faq-icon { font-size: 1.2rem; transition: transform .25s; flex-shrink: 0; color: var(--terracotta); }
    .faq-body {
      max-height: 0; overflow: hidden;
      transition: max-height .35s ease, padding .25s;
      padding: 0 20px; font-size: .92rem; color: var(--text-muted); line-height: 1.75;
    }
    .faq-item.open .faq-body { max-height: 240px; padding-bottom: 18px; }
    .faq-item.open .faq-icon { transform: rotate(45deg); }

    /* ══════════════════════════════════════════════
       BLOC 11 — FORMULAIRE RAPPEL
       ⚠ 2+1 champs : Prénom + Téléphone + Service
       ⚠ UX optimisée seniors (grands labels, contraste)
    ══════════════════════════════════════════════ */
    .rappel {
      background: linear-gradient(135deg, var(--sage-dark) 0%, #3D6B5C 100%);
      position: relative; overflow: hidden;
    }
    .rappel::before {
      content: '';
      position: absolute; top: -100px; right: -150px;
      width: 500px; height: 500px; border-radius: 50%;
      background: rgba(255,255,255,.03); pointer-events: none;
    }
    .rappel .container { position: relative; z-index: 1; }
    .rappel .eyebrow { color: #A8D5C6; }
    .rappel-h2 {
      font-family: var(--ff-head); font-size: clamp(1.6rem, 3vw, 2.2rem);
      color: var(--white); line-height: 1.15; margin-bottom: 12px;
    }
    .rappel-sub { color: rgba(255,255,255,.7); font-size: 1rem; margin-bottom: 36px; max-width: 480px; }
    .rappel-grid {
      display: grid; grid-template-columns: 1fr 420px;
      gap: 64px; align-items: start;
    }
    @media (max-width: 820px) { .rappel-grid { grid-template-columns: 1fr; gap: 36px; } }
    .rappel-feats { list-style: none; display: flex; flex-direction: column; gap: 14px; }
    .rappel-feats li {
      display: flex; align-items: center; gap: 12px;
      color: rgba(255,255,255,.85); font-size: .93rem;
    }
    .rf-check {
      width: 26px; height: 26px; border-radius: 50%;
      background: rgba(168,213,198,.2); color: #A8D5C6;
      font-size: .85rem; font-weight: 700;
      display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }

    /* ⚠ Formulaire — UX seniors : labels grands, champs hauts */
    .lead-form {
      background: var(--white); border-radius: var(--radius-lg);
      padding: 36px; box-shadow: var(--shadow-lg);
    }
    .lead-form h3 {
      font-family: var(--ff-head); font-size: 1.3rem;
      color: var(--sage-dark); margin-bottom: 6px;
    }
    .lead-form .form-intro {
      font-size: .88rem; color: var(--text-muted); margin-bottom: 24px;
    }
    .fg { margin-bottom: 16px; }
    .fg label {
      display: block; font-weight: 600; font-size: .88rem;
      color: var(--sage-dark); margin-bottom: 7px;
    }
    .fg input, .fg select {
      width: 100%; padding: 14px 16px;
      border: 1.5px solid rgba(45,82,72,.2);
      border-radius: 10px; font-family: var(--ff-body);
      font-size: 1rem; /* ⚠ min 16px sur mobile — évite zoom iOS */
      color: var(--text-main); background: var(--white);
      transition: border-color .2s; outline: none; appearance: none;
    }
    .fg input:focus, .fg select:focus { border-color: var(--sage); }
    .form-btn {
      width: 100%; padding: 16px; border: none; border-radius: 50px;
      background: var(--terracotta); color: var(--white);
      font-family: var(--ff-body); font-weight: 700; font-size: 1rem;
      cursor: pointer; transition: all .25s var(--ease); margin-top: 8px;
      box-shadow: 0 4px 16px rgba(196,98,58,.3);
    }
    .form-btn:hover { background: #ad5430; transform: translateY(-2px); }
    .form-legal {
      font-size: .73rem; color: var(--text-muted);
      margin-top: 12px; text-align: center; line-height: 1.5;
    }

    /* ══════════════════════════════════════════════
       BLOC 12 — FOOTER
       ⚠ NAP identique au topbar + schema.org
    ══════════════════════════════════════════════ */
    .site-footer { background: #1A2E28; padding: 52px 0 24px; }
    .footer-grid {
      display: grid; grid-template-columns: 1.6fr 1fr 1fr;
      gap: 40px; margin-bottom: 40px;
    }
    @media (max-width: 640px) { .footer-grid { grid-template-columns: 1fr; } }
    .footer-logo { font-size: 1.5rem; margin-bottom: 14px; }
    .footer-desc { font-size: .85rem; color: rgba(255,255,255,.5); line-height: 1.7; margin-bottom: 18px; }
    .footer-nap span { display: block; font-size: .84rem; color: rgba(255,255,255,.45); margin-bottom: 4px; }
    .footer-nap a { color: #A8D5C6; font-weight: 600; font-size: .92rem; }
    .footer-col h4 {
      font-family: var(--ff-body); font-weight: 700; font-size: .88rem;
      color: rgba(255,255,255,.9); margin-bottom: 16px;
      padding-bottom: 8px; border-bottom: 1px solid rgba(255,255,255,.08);
    }
    .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 8px; }
    .footer-col ul li a { font-size: .84rem; color: rgba(255,255,255,.45); transition: color .2s; }
    .footer-col ul li a:hover { color: #A8D5C6; }
    .footer-bottom {
      border-top: 1px solid rgba(255,255,255,.06);
      padding-top: 20px; display: flex;
      justify-content: space-between; flex-wrap: wrap; gap: 8px;
    }
    .footer-bottom span { font-size: .78rem; color: rgba(255,255,255,.3); font-family: var(--ff-body); }

    /* ══════════════════════════════════════════════
       STICKY CTA MOBILE
       ⚠ Uniquement ≤768px — Z-index supérieur au header
    ══════════════════════════════════════════════ */
    .sticky-cta {
      display: none;
      position: fixed; bottom: 0; left: 0; right: 0; z-index: 200;
      padding: 13px 20px;
      background: var(--terracotta);
      box-shadow: 0 -4px 20px rgba(0,0,0,.15);
    }
    .sticky-cta a {
      display: flex; align-items: center; justify-content: center; gap: 10px;
      color: var(--white); font-family: var(--ff-body);
      font-weight: 700; font-size: 1rem;
    }
    @media (max-width: 768px) {
      .sticky-cta { display: block; }
      body { padding-bottom: 58px; }
    }

    /* ══════ ANIMATIONS ══════════════════════ */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(22px); }
      to   { opacity: 1; transform: translateY(0); }
    }
  </style>
</head>
<body>

  <!-- ══════════════════════════════════════════════
       TOPBAR — NAP compact
       ⚠ Même NAP que footer + GBP + annuaires
  ══════════════════════════════════════════════ -->
  <div class="topbar">
    <div class="container">
      <span>📍 12 Allée Jean Jaurès, 31000 Toulouse</span>
      <span>🕗 Livraisons 7j/7 · 11h–13h &amp; 18h–20h</span>
      <a href="tel:+33500000000" onclick="trackCall('topbar')">📞 05 00 00 00 00</a>
    </div>
  </div>

  <!-- ══════════════════════════════════════════════
       HEADER — sticky, logo + téléphone + CTA
  ══════════════════════════════════════════════ -->
  <header class="site-header">
    <div class="container">
      <div class="logo">
        <div class="logo-badge" aria-hidden="true">🍽️</div>
        <div>
          <div class="logo-name">AXEO Services Toulouse</div>
          <div class="logo-tag">Livraison repas à domicile pour seniors</div>
        </div>
      </div>
      <a href="tel:+33500000000" class="header-tel" onclick="trackCall('header_tel')">05 00 00 00 00</a>
      <a href="tel:+33500000000" class="btn-primary" onclick="trackCall('header_cta')">
        📞 Appeler maintenant
      </a>
    </div>
  </header>

  <!-- ══════════════════════════════════════════════
       HERO
       ⚠ H1 = requête principale + localisation
       ⚠ Bullets = délai / zone / prix
       ⚠ Preuve sociale AVANT défilement
  ══════════════════════════════════════════════ -->
  <section class="hero" aria-label="Présentation du service">
    <div class="container">
      <div class="hero-left">
        <span class="pill">🍽️ Toulouse &amp; agglomération</span>

        <!-- ⚠ H1 — mot-clé de volume + ville — unique par page -->
        <h1>
          Livraison de repas à domicile<br>
          pour seniors à <span>Toulouse</span>
        </h1>

        <p class="hero-sub">
          Des repas équilibrés, chauds ou froids, livrés 7j/7 chez votre proche.
          Adaptés aux régimes spéciaux, préparés par des cuisiniers locaux.
        </p>

        <!-- ⚠ 3 bullets ultra-concrètes -->
        <ul class="hero-bullets" aria-label="Avantages principaux">
          <li>
            <span class="hb-icon">🚚</span>
            <span class="hb-text">
              <strong>Livraison 7j/7 à domicile</strong>
              <span>Midi et soir — créneau au choix — Toulouse &amp; 25 communes</span>
            </span>
          </li>
          <li>
            <span class="hb-icon">💶</span>
            <span class="hb-text">
              <strong>À partir de 4,25€ net après crédit d'impôt 50%</strong>
              <span>Aides APA / CARSAT / CCAS cumulables selon situation</span>
            </span>
          </li>
          <li>
            <span class="hb-icon">⚡</span>
            <span class="hb-text">
              <strong>Première livraison sous 48h</strong>
              <span>Devis gratuit — sans engagement — résiliable à tout moment</span>
            </span>
          </li>
        </ul>

        <div class="hero-ctas">
          <a href="tel:+33500000000" class="btn-primary" onclick="trackCall('hero_cta')">
            📞 Appeler maintenant
          </a>
          <a href="#rappel" class="btn-ghost">Être rappelé gratuitement →</a>
        </div>
      </div>

      <!-- ⚠ Preuve sociale au-dessus de la ligne de flottaison -->
      <div class="hero-visual" aria-label="Avis clients">
        <div class="hero-plate">
          <span class="plate-emoji">🍲</span>
          <div class="plate-title">Repas du jour</div>
          <div class="plate-sub">Livré chaud, entre 11h30 et 13h00</div>
          <div class="rating-row">
            <span class="stars">★★★★★</span>
            <span class="rating-score">4,8/5</span>
            <span class="rating-count">· 94 avis Google</span>
          </div>
          <div class="mini-review">
            <p>"Notre mère mange mieux qu'avant. Les plats sont variés, bien chauds et la livreuse est adorable."</p>
            <div class="mini-review-meta">Françoise D. — Toulouse 4ème — Fille aidante</div>
            <span class="mini-review-result">✓ Abonnée depuis 14 mois</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       TRUST BAR
  ══════════════════════════════════════════════ -->
  <div class="trust-bar">
    <div class="container">
      <div class="trust-item"><span class="ti">🍽️</span> +350 repas livrés chaque jour</div>
      <div class="trust-item"><span class="ti">👨‍🍳</span> Cuisiniers locaux partenaires</div>
      <div class="trust-item"><span class="ti">🛡️</span> Agréé SAP — Crédit impôt 50%</div>
      <div class="trust-item"><span class="ti">📍</span> 25 communes desservies</div>
      <div class="trust-item"><span class="ti">🔄</span> Sans engagement de durée</div>
    </div>
  </div>

  <!-- ══════════════════════════════════════════════
       OFFRE REPAS — 3 formules
       ⚠ Ancre le prix + lève l'objection du budget
  ══════════════════════════════════════════════ -->
  <section class="offre" id="offre" aria-labelledby="offre-title">
    <div class="container">
      <span class="eyebrow">Nos formules</span>
      <h2 class="section-h2" id="offre-title">
        Choisissez la formule <em>adaptée</em><br>à votre proche
      </h2>
      <p class="section-intro">
        Toutes les formules incluent la livraison, l'emballage isotherme et le suivi personnalisé.
        Prix nets après crédit d'impôt de 50%.
      </p>

      <div class="offre-grid">

        <!-- Formule Essentiel -->
        <div class="offre-card">
          <div class="offre-icon">🥗</div>
          <h3>Essentiel</h3>
          <div class="offre-price">4,25€ <small style="font-size:.9rem;font-weight:400;color:var(--text-muted)">/repas net</small></div>
          <div class="offre-sub">≈ 8,50€ brut · crédit impôt 50%</div>
          <ul class="offre-list">
            <li><span class="offre-check">✓</span> 1 repas/jour (midi ou soir)</li>
            <li><span class="offre-check">✓</span> Plat + dessert</li>
            <li><span class="offre-check">✓</span> Livraison 5j/7</li>
            <li><span class="offre-check">✓</span> Menu hebdomadaire varié</li>
          </ul>
        </div>

        <!-- Formule Confort — mise en avant -->
        <div class="offre-card featured" aria-label="Formule la plus choisie">
          <div class="featured-badge">⭐ Le plus choisi</div>
          <div class="offre-icon">🍱</div>
          <h3>Confort</h3>
          <div class="offre-price">5,75€ <small style="font-size:.9rem;font-weight:400;opacity:.7">/repas net</small></div>
          <div class="offre-sub" style="color:rgba(255,255,255,.55)">≈ 11,50€ brut · crédit impôt 50%</div>
          <ul class="offre-list">
            <li><span class="offre-check">✓</span> 2 repas/jour (midi + soir)</li>
            <li><span class="offre-check">✓</span> Entrée + plat + dessert</li>
            <li><span class="offre-check">✓</span> Livraison 7j/7</li>
            <li><span class="offre-check">✓</span> Adaptation régime incluse</li>
            <li><span class="offre-check">✓</span> Suivi nutritionnel mensuel</li>
          </ul>
        </div>

        <!-- Formule Premium -->
        <div class="offre-card">
          <div class="offre-icon">🍽️</div>
          <h3>Premium</h3>
          <div class="offre-price">7,50€ <small style="font-size:.9rem;font-weight:400;color:var(--text-muted)">/repas net</small></div>
          <div class="offre-sub">≈ 15,00€ brut · crédit impôt 50%</div>
          <ul class="offre-list">
            <li><span class="offre-check">✓</span> 3 repas/jour complets</li>
            <li><span class="offre-check">✓</span> Entrée + plat + fromage + dessert</li>
            <li><span class="offre-check">✓</span> Livraison 7j/7 dont dimanches</li>
            <li><span class="offre-check">✓</span> Bilan diététique trimestriel</li>
            <li><span class="offre-check">✓</span> Contact famille dédié</li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       RÉGIMES SPÉCIAUX
       ⚠ Objection #1 famille : "mon parent a un régime"
  ══════════════════════════════════════════════ -->
  <section class="regimes" aria-labelledby="regimes-title">
    <div class="container">
      <span class="eyebrow">Adaptations alimentaires</span>
      <h2 class="section-h2" id="regimes-title">
        Des menus pensés pour <em>chaque</em> besoin
      </h2>
      <p class="section-intro">
        Chaque senior est différent. Nous adaptons chaque repas selon les besoins médicaux
        et les préférences de votre proche, sans surcoût.
      </p>
      <div class="regimes-grid">
        <div class="regime-chip"><div class="re">🧂</div><p>Sans sel / hyposodé</p></div>
        <div class="regime-chip"><div class="re">🍬</div><p>Diabétique / sans sucre</p></div>
        <div class="regime-chip"><div class="re">🥄</div><p>Mixé / haché fin</p></div>
        <div class="regime-chip"><div class="re">🥛</div><p>Sans lactose</p></div>
        <div class="regime-chip"><div class="re">🌾</div><p>Sans gluten</p></div>
        <div class="regime-chip"><div class="re">🐖</div><p>Sans porc / hallal</p></div>
        <div class="regime-chip"><div class="re">🌿</div><p>Végétarien</p></div>
        <div class="regime-chip"><div class="re">💊</div><p>Troubles déglutition</p></div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       PROCESSUS — 3 étapes
  ══════════════════════════════════════════════ -->
  <section class="process" aria-labelledby="process-title">
    <div class="container">
      <span class="eyebrow">Comment ça marche ?</span>
      <h2 class="section-h2" id="process-title">Démarrer en 3 étapes simples</h2>
      <div class="process-steps">
        <div class="pstep">
          <div class="pstep-num">1</div>
          <h3>On vous rappelle</h3>
          <p>Appelez-nous ou laissez votre numéro. Un conseiller vous contact sous 2h pour évaluer les besoins.</p>
        </div>
        <div class="pstep">
          <div class="pstep-num">2</div>
          <h3>Devis gratuit sous 24h</h3>
          <p>On établit ensemble la formule adaptée, le régime alimentaire et les créneaux de livraison.</p>
        </div>
        <div class="pstep">
          <div class="pstep-num">3</div>
          <h3>1ère livraison sous 48h</h3>
          <p>Votre proche reçoit ses premiers repas. Un suivi régulier est organisé pour ajuster si besoin.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       ZONE + HORAIRES
  ══════════════════════════════════════════════ -->
  <section class="zone" id="zone" aria-labelledby="zone-title">
    <div class="container">
      <span class="eyebrow">Zone &amp; horaires</span>
      <h2 class="section-h2" id="zone-title">
        Livraison à <em>Toulouse</em> et alentours
      </h2>
      <div class="zone-grid">
        <div>
          <p style="font-size:.93rem;color:var(--text-muted);margin-bottom:18px;">
            Nous livrons dans un rayon de 30 km autour de Toulouse, 7 jours sur 7 :
          </p>
          <div class="zone-pills">
            <span class="zone-pill">Toulouse</span><span class="zone-pill">Blagnac</span>
            <span class="zone-pill">Colomiers</span><span class="zone-pill">Tournefeuille</span>
            <span class="zone-pill">Balma</span><span class="zone-pill">Labège</span>
            <span class="zone-pill">Castanet</span><span class="zone-pill">Ramonville</span>
            <span class="zone-pill">Muret</span><span class="zone-pill">Saint-Orens</span>
            <span class="zone-pill">Cugnaux</span><span class="zone-pill">Plaisance-du-Touch</span>
          </div>
          <div class="map-placeholder">
            <span>🗺️</span>
            <strong>Carte de la zone (iframe Google Maps)</strong>
            <small>Centrer sur Toulouse · Rayon 30 km</small>
          </div>
          <p style="font-size:.84rem;color:var(--text-muted);">
            Votre commune n'est pas listée ?
            <a href="tel:+33500000000" onclick="trackCall('zone')" style="color:var(--sage);font-weight:600;">Appelez-nous</a> — nous étudions chaque demande.
          </p>
        </div>

        <div class="horaires-card" aria-label="Horaires de livraison">
          <h4>🕐 Créneaux de livraison</h4>
          <div class="horaire-row">
            <span class="horaire-day">Lundi – Vendredi</span>
            <span class="horaire-time">11h30–13h &amp; 18h–19h30</span>
          </div>
          <div class="horaire-row">
            <span class="horaire-day">Samedi</span>
            <span class="horaire-time">11h30–13h &amp; 18h–19h30</span>
          </div>
          <div class="horaire-row">
            <span class="horaire-day">Dimanche</span>
            <span class="horaire-time">11h30–13h (formule Premium)</span>
          </div>
          <div class="horaire-row" style="border:none;padding-top:16px;margin-top:8px;">
            <span style="color:rgba(255,255,255,.65);font-size:.82rem;">📞 Commandes et modifications :</span>
            <a href="tel:+33500000000" onclick="trackCall('horaires')" style="color:#A8D5C6;font-weight:700;font-size:.88rem;">05 00 00 00 00</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       TÉMOIGNAGES — résultats chiffrés
  ══════════════════════════════════════════════ -->
  <section class="testi" aria-labelledby="testi-title">
    <div class="container">
      <span class="eyebrow">Avis vérifiés</span>
